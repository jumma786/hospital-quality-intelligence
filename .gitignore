# Large data files (exceed GitHub limits / not source)
data/*.csv

# Local tooling / config
.claude/

# OS / editor cruft
Thumbs.db
.DS_Store
*.log

# ML artifacts — the large trained models are regenerable from ml/src/train_models.py.
# The small derived CSVs (scored_hospitals, hospital_features) ARE committed so the
# Streamlit Cloud app has its data layer without the raw CSVs or the .joblib models.
ml/outputs/*.joblib
__pycache__/
*.pyc

# Longitudinal pipeline: simulated snapshots + large regenerable panels are not
# committed. The small watermarked demo chart + national_trends.csv are kept.
data/snapshots/
ml/outputs/hospital_panel.csv
ml/outputs/hospital_trends.csv
